PORT=5000

# --- MongoDB ---
# Développement local (sans Docker) :
MONGO_URI=mongodb://127.0.0.1:27017/sama-chantier
# Avec docker compose (dossier sama-chantier-frontend) : décommenter la ligne suivante et commenter celle du dessus
# MONGO_URI=mongodb://mongo:27017/sama-chantier

JWT_SECRET=change_me
JWT_EXPIRE=30d

# Origine autorisée CORS : doit correspondre à l’URL du navigateur
# Vite seul : http://localhost:5173
# Docker (nginx sur 8080) : http://localhost:8080
CLIENT_URL=http://localhost:5173

# URL publique de l’API (CinetPay : notify_url). En local pur, CinetPay ne peut pas joindre localhost.
# Docker : http://localhost:5000 si le port 5000 est exposé ; en production : https://api.votredomaine.sn
API_PUBLIC_URL=http://localhost:5000

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CinetPay (https://docs.cinetpay.com)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# E-mail (nodemailer)
# Production : renseigner SMTP_* (Brevo, Gmail, OVH…)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Sama Chantier <noreply@example.com>"
# Développement sans SMTP : Ethereal (faux boîte) + lien de prévisualisation dans la console Node.
# Désactiver ce mode : MAIL_DEV=0 ou NODE_ENV=production sans SMTP
# MAIL_DEV=0
